NODE_ENV=development
PORT=5000
MONGO_URI=mongodb://127.0.0.1:27017/petcare
MONGO_DB_NAME=petcare
MONGO_ALLOW_LOCAL_FALLBACK=false
MONGO_MAX_POOL_SIZE=50
MONGO_MIN_POOL_SIZE=10
MONGO_MAX_IDLE_TIME_MS=10000
MONGO_COMPRESSORS=zlib,snappy
MONGO_ZLIB_COMPRESSION_LEVEL=6
CLIENT_ORIGIN=http://localhost:5173

# Clerk
CLERK_SECRET_KEY=sk_...

# Groq AI
GROQ_API_KEY=replace_me
GROQ_MODEL=llama-3.1-8b-instant

# Email (Resend)
RESEND_API_KEY=re_xxxxx

# Admin role auto-assign if email matches
SEED_ADMIN_EMAIL=admin@petcare.local
